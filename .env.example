NODE_ENV=production
HOST=0.0.0.0
PORT=4280

AUTH_API_BASE_URL=
AUTH_ADMIN_PHONE=13800000000
AUTH_ADMIN_DISPLAY_NAME=海总管理员
AUTH_ADMIN_PASSWORD=replace_with_a_strong_admin_password
AUTH_TOKEN_SECRET=replace_with_a_long_random_secret
AUTH_SESSION_TTL_MS=28800000
AUTH_USERS_PATH=server/data/auth-users.json

CONTENT_STORAGE_PATH=src/data/content.json
CONTENT_READONLY=false

TAVILY_API_KEY=your_tavily_api_key
TAVILY_BASE_URL=https://api.tavily.com/search

DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional: AI assistant can use a separate DeepSeek-compatible key.
# If unset, the assistant falls back to DEEPSEEK_* above.
AGENT_DEEPSEEK_API_KEY=your_agent_deepseek_api_key
AGENT_DEEPSEEK_BASE_URL=https://api.deepseek.com
AGENT_DEEPSEEK_MODEL=deepseek-chat

JUSTONEAPI_TOKEN=your_justoneapi_token
# JUSTONEAPI_BASE_URL=https://api.justoneapi.com
# JUSTONEAPI_TIMEOUT_MS=15000
